{
  // Code Quality
  "editor.formatOnSave": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always",
    "source.fixAll.eslint": "always",
    // Used for verifying fixture outputs
    "source.fixAll.stylelint": "never",
    "source.organizeImports": "never"
  },
  "eslint.validate": [
    // Code
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue",
    // Configurations
    "json",
    "jsonc",
    "yaml",
    "toml",
    // Documentations
    "markdown"
  ],
  // Used for verifying fixture outputs
  "stylelint.validate": [
    // Code
    "css",
    "postcss",
    "scss",
    "less",
    "html",
    "vue"
  ]
}
