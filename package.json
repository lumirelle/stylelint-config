{
  "name": "@lumirelle/stylelint-config",
  "type": "module",
  "version": "5.0.0-beta.7",
  "packageManager": "bun@1.3.14",
  "description": "Lumirelle's StyleLint config",
  "author": "Lumirelle <shabbyacc@outlook.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/lumirelle",
  "homepage": "https://github.com/lumirelle/stylelint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumirelle/stylelint-config.git"
  },
  "bugs": "https://github.com/lumirelle/stylelint-config/issues",
  "keywords": [
    "stylelint",
    "stylelint-config",
    "css",
    "scss",
    "vue",
    "lumirelle"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "tsdown --tsconfig tsconfig.lib.json --watch",
    "build": "tsdown --tsconfig tsconfig.lib.json --publint --attw.profile esm-only",
    "start": "bun run ./src/index.ts",
    "lint": "bun run --parallel oxlint eslint",
    "lint:fix": "oxlint --fix && eslint --fix",
    "typecheck": "tsc --build --noEmit",
    "unused": "knip-bun",
    "check": "bun run --parallel lint typecheck unused",
    "pretest": "bun run build",
    "test": "bun test",
    "prerelease": "bun run --parallel check test",
    "release": "bumpp"
  },
  "workspaces": {
    "packages": [],
    "catalogs": {
      "dev": {
        "bumpp": "^11.1.0",
        "postcss-less": "^6.0.0",
        "stylelint": "^17.12.0",
        "stylelint-less": "^4.2.1"
      },
      "types": {
        "@lumirelle/tsconfig": "^0.1.4",
        "@types/lodash.clonedeep": "^4.5.9",
        "@types/node": "^25.9.1",
        "@types/postcss-less": "^4.0.7",
        "@types/semver": "^7.7.1",
        "bun-types": "^1.3.14",
        "typescript": "^6.0.3"
      },
      "build": {
        "tsdown": "^0.22.0"
      },
      "prod": {
        "@antfu/install-pkg": "^1.1.0",
        "@antfu/utils": "^9.3.0",
        "@clack/prompts": "^1.4.0",
        "@dreamsicle.io/stylelint-config-tailwindcss": "^1.2.2",
        "@lumirelle/defu": "^1.1.0",
        "@stylistic/stylelint-config": "^5.0.0",
        "local-pkg": "^1.2.1",
        "lodash.clonedeep": "^4.5.0",
        "postcss-scss": "^4.0.9",
        "semver": "^7.8.1",
        "stylelint-config-html": "^1.1.0",
        "stylelint-config-recess-order": "^7.7.0",
        "stylelint-scss": "^7.1.1"
      },
      "check": {
        "@antfu/eslint-config": "^9.0.0",
        "@arethetypeswrong/cli": "^0.18.2",
        "@lumirelle/oxlint-config": "^0.6.0",
        "eslint": "^10.4.0",
        "eslint-plugin-oxlint": "^1.66.0",
        "knip": "^6.14.2",
        "nano-staged": "^1.0.2",
        "oxlint": "^1.66.0",
        "oxlint-tsgolint": "^0.23.0",
        "publint": "^0.3.21",
        "simple-git-hooks": "git+https://github.com/toplenboren/simple-git-hooks.git#7625657"
      },
      "test": {
        "tsnapi": "^0.3.3"
      }
    }
  },
  "peerDependencies": {
    "postcss-less": ">=6.0.0",
    "stylelint": ">=17.0.0",
    "stylelint-less": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "postcss-less": {
      "optional": true
    },
    "stylelint-less": {
      "optional": true
    }
  },
  "dependencies": {
    "@antfu/install-pkg": "catalog:prod",
    "@antfu/utils": "catalog:prod",
    "@clack/prompts": "catalog:prod",
    "@dreamsicle.io/stylelint-config-tailwindcss": "catalog:prod",
    "@lumirelle/defu": "catalog:prod",
    "@stylistic/stylelint-config": "catalog:prod",
    "local-pkg": "catalog:prod",
    "lodash.clonedeep": "catalog:prod",
    "postcss-scss": "catalog:prod",
    "semver": "catalog:prod",
    "stylelint-config-html": "catalog:prod",
    "stylelint-config-recess-order": "catalog:prod",
    "stylelint-scss": "catalog:prod"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:check",
    "@arethetypeswrong/cli": "catalog:check",
    "@lumirelle/oxlint-config": "catalog:check",
    "@lumirelle/tsconfig": "catalog:types",
    "@types/lodash.clonedeep": "catalog:types",
    "@types/node": "catalog:types",
    "@types/postcss-less": "catalog:types",
    "@types/semver": "catalog:types",
    "bumpp": "catalog:dev",
    "bun-types": "catalog:types",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "knip": "catalog:check",
    "nano-staged": "catalog:check",
    "oxlint": "catalog:check",
    "oxlint-tsgolint": "catalog:check",
    "postcss-less": "catalog:dev",
    "publint": "catalog:check",
    "simple-git-hooks": "catalog:check",
    "stylelint": "catalog:dev",
    "stylelint-less": "catalog:dev",
    "tsdown": "catalog:build",
    "tsnapi": "catalog:test",
    "typescript": "catalog:types"
  },
  "overrides": {
    "fflate": "0.8.2"
  },
  "simple-git-hooks": {
    "pre-commit": "bun nano-staged"
  },
  "nano-staged": {
    "*": [
      "oxlint --no-error-on-unmatched-pattern",
      "eslint"
    ]
  }
}
