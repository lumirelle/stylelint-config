{
  "name": "@lumirelle/stylelint-config",
  "type": "module",
  "version": "5.0.0-beta.8",
  "packageManager": "aube@1.22.0",
  "description": "Lumirelle's StyleLint config",
  "author": "Lumirelle <shabbyacc@outlook.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/lumirelle",
  "homepage": "https://github.com/lumirelle/stylelint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumirelle/stylelint-config.git"
  },
  "bugs": "https://github.com/lumirelle/stylelint-config/issues",
  "keywords": [
    "stylelint",
    "stylelint-config",
    "css",
    "scss",
    "vue",
    "lumirelle"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "workspaces": {
    "packages": [],
    "catalogs": {
      "dev": {
        "postcss-less": "^6.0.0",
        "stylelint": "^17.13.0",
        "stylelint-less": "^4.2.1",
        "taze": "^19.14.1"
      },
      "types": {
        "@lumirelle/tsconfig": "^0.1.4",
        "@types/bun": "^1.3.14",
        "@types/lodash.clonedeep": "^4.5.9",
        "@types/node": "^25.9.3",
        "@types/postcss-less": "^4.0.7",
        "@types/semver": "^7.7.1",
        "typescript": "^6.0.3"
      },
      "build": {
        "tsdown": "^0.22.3"
      },
      "prod": {
        "@antfu/install-pkg": "^1.1.0",
        "@antfu/utils": "^9.3.0",
        "@clack/prompts": "^1.5.1",
        "@dreamsicle.io/stylelint-config-tailwindcss": "^1.2.2",
        "@lumirelle/defu": "^1.1.0",
        "@stylistic/stylelint-config": "^5.0.0",
        "local-pkg": "^1.2.1",
        "lodash.clonedeep": "^4.5.0",
        "postcss-scss": "^4.0.9",
        "semver": "^7.8.4",
        "stylelint-config-html": "^1.1.0",
        "stylelint-config-recess-order": "^7.7.0",
        "stylelint-scss": "^7.2.0"
      },
      "check": {
        "@antfu/eslint-config": "^9.0.0",
        "@arethetypeswrong/cli": "^0.18.4",
        "@lumirelle/oxlint-config": "^0.9.1",
        "eslint": "^10.5.0",
        "eslint-plugin-oxlint": "^1.70.0",
        "knip": "^6.17.1",
        "oxlint": "^1.70.0",
        "oxlint-tsgolint": "^0.23.0",
        "publint": "^0.3.21"
      },
      "test": {
        "@vitest/coverage-v8": "^4.1.9",
        "tsnapi": "^0.3.3",
        "vitest": "^4.1.9"
      },
      "release": {
        "bumpp": "^11.1.0",
        "changelogithub": "^14.0.0",
        "npm": "^11.17.0",
        "pkg-pr-new": "^0.0.75"
      }
    }
  },
  "peerDependencies": {
    "postcss-less": ">=6.0.0",
    "stylelint": ">=17.0.0",
    "stylelint-less": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "postcss-less": {
      "optional": true
    },
    "stylelint-less": {
      "optional": true
    }
  },
  "dependencies": {
    "@antfu/install-pkg": "catalog:prod",
    "@antfu/utils": "catalog:prod",
    "@clack/prompts": "catalog:prod",
    "@dreamsicle.io/stylelint-config-tailwindcss": "catalog:prod",
    "@lumirelle/defu": "catalog:prod",
    "@stylistic/stylelint-config": "catalog:prod",
    "local-pkg": "catalog:prod",
    "lodash.clonedeep": "catalog:prod",
    "postcss-scss": "catalog:prod",
    "semver": "catalog:prod",
    "stylelint-config-html": "catalog:prod",
    "stylelint-config-recess-order": "catalog:prod",
    "stylelint-scss": "catalog:prod"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:check",
    "@arethetypeswrong/cli": "catalog:check",
    "@lumirelle/oxlint-config": "catalog:check",
    "@lumirelle/tsconfig": "catalog:types",
    "@types/bun": "catalog:types",
    "@types/lodash.clonedeep": "catalog:types",
    "@types/node": "catalog:types",
    "@types/postcss-less": "catalog:types",
    "@types/semver": "catalog:types",
    "@vitest/coverage-v8": "catalog:test",
    "bumpp": "catalog:release",
    "changelogithub": "catalog:release",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "knip": "catalog:check",
    "npm": "catalog:release",
    "oxlint": "catalog:check",
    "oxlint-tsgolint": "catalog:check",
    "pkg-pr-new": "catalog:release",
    "postcss-less": "catalog:dev",
    "publint": "catalog:check",
    "stylelint": "catalog:dev",
    "stylelint-less": "catalog:dev",
    "taze": "catalog:dev",
    "tsdown": "catalog:build",
    "tsnapi": "catalog:test",
    "typescript": "catalog:types",
    "vitest": "catalog:test"
  }
}
