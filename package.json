{
  "name": "@lumirelle/stylelint-config",
  "type": "module",
  "version": "5.0.0-beta.10",
  "packageManager": "nub@0.4.12",
  "description": "Lumirelle's StyleLint config",
  "author": "Lumirelle <shabbyacc@outlook.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/lumirelle",
  "homepage": "https://github.com/lumirelle/stylelint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumirelle/stylelint-config.git"
  },
  "bugs": "https://github.com/lumirelle/stylelint-config/issues",
  "keywords": [
    "stylelint",
    "stylelint-config",
    "css",
    "scss",
    "vue",
    "lumirelle"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "devEngines": {
    "packageManager": {
      "name": "nub",
      "version": "^0.4.12",
      "onFail": "warn"
    }
  },
  "engines": {
    "node": ">22",
    "bun": ">1"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "postcss-less": ">=6.0.0",
    "stylelint": ">=17.0.0",
    "stylelint-less": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "postcss-less": {
      "optional": true
    },
    "stylelint-less": {
      "optional": true
    }
  },
  "dependencies": {
    "@antfu/install-pkg": "^1.1.0",
    "@antfu/utils": "^9.3.0",
    "@clack/prompts": "^1.7.0",
    "@dreamsicle.io/stylelint-config-tailwindcss": "^1.2.2",
    "@lumirelle/defu": "^1.1.0",
    "@stylistic/stylelint-config": "^5.0.0",
    "local-pkg": "^1.2.1",
    "lodash.clonedeep": "^4.5.0",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "semver": "^7.8.5",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-scss": "^7.2.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@arethetypeswrong/cli": "^0.18.5",
    "@lumirelle/oxlint-config": "^0.13.0",
    "@lumirelle/tsconfig": "^0.1.6",
    "@types/bun": "^1.3.14",
    "@types/lodash.clonedeep": "^4.5.9",
    "@types/node": "^26.1.1",
    "@types/postcss-less": "^4.0.7",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.10",
    "bumpp": "^11.1.0",
    "changelogithub": "^14.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-oxlint": "^1.73.0",
    "knip": "^6.27.0",
    "npm": "^12.0.1",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "pkg-pr-new": "^0.0.78",
    "postcss-less": "^6.0.0",
    "publint": "^0.3.21",
    "stylelint": "^17.14.0",
    "stylelint-less": "^4.2.1",
    "taze": "^19.14.1",
    "tsdown": "^0.22.9",
    "tsnapi": "^1.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
