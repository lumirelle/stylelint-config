amends "package://github.com/jdx/hk/releases/download/v1.51.0/hk@1.51.0#/Config.pkl"

import "package://github.com/jdx/hk/releases/download/v1.51.0/hk@1.51.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  // Code
  ["oxlint"] = Builtins.ox_lint
  ["eslint"] = (Builtins.eslint) {
    batch = false
    glob =
      List(
        // Code
        "*.js",
        "*.mjs",
        "*.cjs",
        "*.jsx",
        "*.ts",
        "*.mts",
        "*.cts",
        "*.tsx",
        "*.vue",
        // Configurations
        "*.json",
        "*.jsonc",
        "*.yaml",
        "*.yml",
        "*.toml",
        // Documentations
        "*.md",
        "*.mdc",
        "*.mdx",
      )
    depends = List("oxlint")
  }
  ["tsc"] = Builtins.tsc
  // Unused code
  ["knip"] = (Builtins.knip) {
    check = new Config.Command {
      argv = List("knip", "--no-progress", "--directory", "{{workspace}}")
    }
    // Disable knip auto-fix, because it's dangerous
    fix = null
  }

  // Configurations
  ["stylua"] = (Builtins.stylua) {
    glob = List("**/*.lua")
  }
  ["hk"] {
    glob = List("hk.pkl")
    check = new Config.Command {
      argv = List("hk", "validate")
    }
  }
  ["pkl-format"] {
    glob = List("hk.pkl")
    check_list_files = new Config.Command {
      argv = List("pkl", "format", "--diff-name-only", "{{ files }}")
    }
    fix = new Config.Command {
      argv = List("pkl", "format", "--write", "{{ files }}")
    }
  }
  // Publish configurations
  ["attw"] {
    check = new Config.Command {
      argv = List("attw", "--pack", "--profile", "esm-only")
    }
  }
  ["publint"] {
    check = new Config.Command {
      argv = List("publint", "--pack", "npm")
    }
  }
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = linters
  }
  ["fix"] {
    fix = true
    steps = linters
  }
  ["check"] {
    steps = linters
  }
}
