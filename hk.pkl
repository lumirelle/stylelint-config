amends "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
    ["oxlint"] = (Builtins.ox_lint) {
      glob = List("**/*")
      check = "oxlint --config .oxlintrc.json --no-error-on-unmatched-pattern --deny-warnings {{ files }}"
      fix = "oxlint --config .oxlintrc.json --no-error-on-unmatched-pattern --deny-warnings --fix {{ files }}"
    }
    ["eslint"] = (Builtins.eslint) {
      batch = false
      glob = List("**/*")
      check = "eslint --no-warn-ignored {{ files }}"
      fix = "eslint --no-warn-ignored --fix {{ files }}"
      depends = List("oxlint")
    }

    ["tsc"] = (Builtins.tsc) {
      check = "tsc --build --noEmit"
    }

    ["knip"] = (Builtins.knip) {
      check = "knip-bun --no-progress --directory {{workspace}}"
      fix = "knip-bun --fix --no-progress --directory {{workspace}}"
    }

    ["attw"] {
      check = "attw --pack --profile esm-only"
    }
    ["publint"] {
      check = "publint"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = linters
    }
    ["fix"] {
        fix = true
        steps = linters
    }
    ["check"] {
        steps = linters
    }
}
